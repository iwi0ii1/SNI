%ifndef LS_MACROS_INC
%define LS_MACROS_INC

bits 16

; Loader's things

; Reserved memory range
%define LS_MACROS_BOOT_MEM_BEGIN_OFF 0x500
%define LS_MACROS_BOOT_MEM_END_OFF 0x9FFF

; Temporary memory range
%define LS_MACROS_TMP_MEM_BEGIN_OFF 0xA000
%define LS_MACROS_TMP_MEM_END_SEG 0x9000
%define LS_MACROS_TMP_MEM_END_OFF 0xFFFF


; Stages
%define LS_MACROS_NEXT_STAGES_LBA_BEGIN 1
%define LS_MACROS_NEXT_STAGES_LBA_COUNT 2
%define LS_MACROS_NEXT_STAGES_LOAD_DEST_OFF 0x7E00

; Collected infos
%define LS_MACROS_E820_LOAD_DEST_OFF 0x9000
%define LS_MACROS_VBE_CTRL_INFO_DEST_OFF 0x9C00


; Boot configuration (entries + settings range, not individual domain)
%define LS_MACROS_BOOTCFG_LBA_BEGIN (LS_MACROS_NEXT_STAGES_LBA_BEGIN + LS_MACROS_NEXT_STAGES_LBA_COUNT + 1)
%define LS_MACROS_BOOTCFG_LBA_COUNT 1
%define LS_MACROS_BOOTCFG_LOAD_DEST_OFF (512 * LS_MACROS_NEXT_STAGES_LBA_COUNT + LS_MACROS_NEXT_STAGES_LOAD_DEST_OFF)


; Boot entries general info
%define LS_MACROS_BOOTENTRY_COUNT 15
%define LS_MACROS_BOOTENTRY_SIZEB 34
%define LS_MACROS_BOOTENTRY_SRC_OFF LS_MACROS_BOOTCFG_LOAD_DEST_OFF


; Boot entry fields info
%define LS_MACROS_BOOTENTRY_FIELD_DISPLAY_NAME_BEGIN 0
%define LS_MACROS_BOOTENTRY_FIELD_DISPLAY_NAME_SIZEB 16

%define LS_MACROS_BOOTENTRY_FIELD_LBA_SRC_BEGIN 16
%define LS_MACROS_BOOTENTRY_FIELD_LBA_SRC_SIZEB 4

%define LS_MACROS_BOOTENTRY_FIELD_LBA_COUNT_BEGIN 20
%define LS_MACROS_BOOTENTRY_FIELD_LBA_COUNT_SIZEB 4

%define LS_MACROS_BOOTENTRY_FIELD_LOAD_DEST_BEGIN 24
%define LS_MACROS_BOOTENTRY_FIELD_LOAD_DEST_SIZEB 4

%define LS_MACROS_BOOTENTRY_FIELD_EXTRA_BEGIN 28
%define LS_MACROS_BOOTENTRY_FIELD_EXTRA_SIZEB 6

; Boot settings general info
%define LS_MACROS_BOOTSETTINGS_SIZEB 2
%define LS_MACROS_BOOTSETTINGS_SRC_OFF (LS_MACROS_BOOTENTRY_COUNT * LS_MACROS_BOOTENTRY_SIZEB)


; Boot settings fields info
%define LS_MACROS_BOOTSETTINGS_FIELD_PRIMARY_OPTION_BEGIN 510
%define LS_MACROS_BOOTSETTINGS_FIELD_PRIMARY_OPTION_SIZEB 1

%define LS_MACROS_BOOTSETTINGS_FIELD_EXTRA_BEGIN 511
%define LS_MACROS_BOOTSETTINGS_FIELD_EXTRA_SIZEB 1

%endif